iptables -F
iptables -t nat -F

iptables -P INPUT DROP 
iptables -P FORWARD DROP 

iptables -A INPUT -p icmp -i eth1 -j ACCEPT

iptables -A INPUT -p tcp --dport 22 -i eth1 -j ACCEPT

iptables -A FORWARD -p udp --dport 53 -i eth1 -d 172.16.10.30 -j ACCEPT

iptables -A FORWARD -i eth1 -o eht0 -j ACCEPT

iptables -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

iptables -t nat -A POSTROUTING -o eth0 -j SNAT --to-source 198.51.100.5

iptables -t nat -A PREROUTING -p tcp --dport 80 -i eth0 -j DNAT --to-destination 172.16.10.30:8080
iptables -A FORWARD -i eth0 -o eth1 -p tcp --dport 8080 -d 172.16.10.30 -j ACCEPT