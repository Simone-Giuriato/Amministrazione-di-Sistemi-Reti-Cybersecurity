Host_Alias FE =fe01, fe02
Host_Alias BE =be01, be02

Cmnd_Alias SHELLS= /bin/sh, /bin/bash, /bin/dash
Cmnd_Alias NETMGM= /usr/bin/ss, /usr/bin/ip
Cmnd_Alias LOGREADERS= /usr/bin/tail, /usr/bin/grep, /usr/bin/less

sofia ALL = (ALL:ALL) ALL

lorenzo ALL = (ALL) ALL, !SHELLS

%frontend FE = (root) NETMGM

%backend BE = (root) NETMGM

%audit ALL = (ALL:audit) NOPASSWD: LOGREADERS

martina BE = (www-data:www-data) /usr/bin/curl

giacomo FE = (root) NOPASSWD: /usr/bin/systemctl status

beatrice admin01 = /usr/sbin/useradd

%fronted, %backend ALL = NOPASSWD: /user/sbin/reboot