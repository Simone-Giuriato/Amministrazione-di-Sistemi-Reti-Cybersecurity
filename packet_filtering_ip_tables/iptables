#filter-->chain: INPUT,OUTPUT, FORWARD, consentire o bloccare pacchetti
#nat--> chain: PREROUTING,OUTPUT,POSTROUTING, cambiare indirizzo o porte (destinazione/sorgenti)

# FORWARD = traffico che attraversa il firewall tra reti diverse


#TARGET tabella FILTER:
    #ACCEPT
    #DROP
    #REJECT
    #LOG
    #RETURN

#TARGET tabella NAT: 
    #SNAT: cambia ip/porta di indirizzo sorgente [-j SNAT --to-source X.X.X.X]  [-j SNAT --to-source IP:PORTA]
    #DNAT: cambia ip/porta di indirizzo destinazione [-j DNAT --to-destination X.X.X.X] [-j DNAT --to-destination IP:PORTA]
    #MASQUERADE: SNAT dinamico  [non devi specificare un indirizzo dopo perchè fa lui dinamicamnete] 
    #REDIRECT: dirige un pkt verso la porta locale del sistema

#1 Svuota tutte le regole esistenti delle 2 tabelle (filter,nat, tutte le chain)

iptables -F     #svuota tutte le regole della tabella predefinita, cioè la tabella filter.  [elimino le regole, di lor avranno delle policy di default tipo ACCEPT, DROP tutto]
iptables -t nat -F  #-t nat--> Qui specifichi la tabella nat (-t sceglie la tabella)

#2 Default deny (DROP) su INPUT e FORWARD (scarta tutto ciò che non è consentito su INPUT e FORWARD), (filter,input,forward)

#-P imposta una policy (ACCEPT,DROP,REJECTED...)
iptables -P INPUT DROP   #Se un pacchetto arriva nella chain INPUT e non matcha nessuna regola, allora scartalo.
iptables -P FORWARD DROP

#3 Accetta ICMP su eth1 (rete privata) verso il firewall, (filter,input)


#-A-->aggiunge una regola (lunga non una policy e basta) alla chain
#-i-->solo per pkt che arrivano su quell'interfaccia, (-o che escono da quell'interfaccia)
#-p--> pkt di quel protocollo(icmp,tcp,udp... [no ssh/telent/http/https...])
#-j--> jump, azione da fare (policy a fine regola)


iptables -A INPUT -i eth1 -p icmp -j ACCEPT


#4 Accetta SSH (tcp/22) su eth1, (filter input)
# --dport--> porta destinazione
iptables -A INPUT -i eth1 -p tcp --dport 22 -j ACCEPT

#5 Consenti i pacchetti HTTP ( tcp/80 ) e HTTPS ( tcp/443 ) ricevuti su eth0 e eth1, (filter,forward)

iptables -A FORWARD -i eth1 -p tcp --dport 80 -j ACCEPT
iptables -A FORWARD -i eth1 -p tcp --dport 443 -j ACCEPT
iptables -A FORWARD -i eth0 -p tcp --dport 80 -j ACCEPT
iptables -A FORWARD -i eth0 -p tcp --dport 443 -j ACCEPT

#6 Consenti i pacchetti con stato ESTABLISHED,RELATED (filter, forward)

#-m conntrack-->Attiva il modulo connection tracking, serve a “ricordare” lo stato delle connessioni: NEW,ESTABLISHED,RELATED,INVALID
#--ctstate ESTABLISHED,RELATED--> connessioni con quei stati

iptables -A FORWARD -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT


#7 MASQUERADE i pacchetti in uscita da eth0 affinché gli host privati ricevano risposte da Internet (nat,POSTROUTING)
#-t "table" selezioni una tabella, di default c'è la filter
#-o --> in uscita dall'interfaccia

iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE

#8   DNAT per i pacchetti HTTP ( tcp/80 ) ricevuti su eth0 , inoltrandoli a 10.20.30.100:8080 e assicurandosi che possano raggiungere quell'host (nat PREROUTING ma con attraverso--> FORWARD)

iptables -t nat -A PREROUTING -i eth0 -p tcp --dport 80 -j DNAT --to-destination 10.20.30.100:8080
iptables -A FORWARD -i eth0 -o eth1 -p tcp -d 10.20.30.100 --dport 8080 -j ACCEPT   #assicurandosi che possano raggiungere quell'host--> “Permetti ai pacchetti HTTP già tradotti (DNAT) di attraversare il firewall (arrivano in eth0 e escono in eth1 privata) e arrivare al server interno 10.20.30.100 sulla porta 8080.”

#specifico ingresso eth0 e uscita eth1
# poi il portoccolo
# l'indirizzo di destinatione che fa coppia con la porta

#iptables -A FORWARD -i eth0 -o eth1 -p tcp --dport 8080 -d 10.20.30.100 -j ACCEPT  #NON DOVREBBE CAMBIARE, se inverto l'ordine delle opzioni


#9 DNAT per i pacchetti HTTPS ( tcp/443 ) ricevuti su eth0 , inoltrandoli a 10.20.30.100:8443 e assicurandosi che possano raggiungere quell'host (nat PREROUTING ma attraverso--> FORWARD)

iptables -t nat -A PREROUTING -i eth0 -p tcp --dport 443 -j DNAT --to-destination 10.20.30.100:8443
iptables -A FORWARD -i eth0 -o eth1 -p tcp --dport 8443 -d 10.20.30.100 -j ACCEPT

